# ── Convex (thestockie deployment) ───────────────────────────────────────────
# The .convex.site origin (HTTP actions), NOT the .convex.cloud one.
CONVEX_SITE_URL=https://exciting-bee-603.convex.site
# Must match the INGEST_SECRET set in Convex:  npx convex env set INGEST_SECRET ...
INGEST_SECRET=replace-with-a-long-random-string

# ── Ollama Cloud (extraction + synthesis) ────────────────────────────────────
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=replace-with-your-ollama-cloud-key
OLLAMA_MODEL=deepseek-v4-flash

# ── Transcription toolchain ──────────────────────────────────────────────────
WHISPER_BIN=whisper-cli
WHISPER_MODEL=models/ggml-large-v3-turbo.bin
WHISPER_MODEL_MEDIUM=models/ggml-medium.bin
LONG_VIDEO_THRESHOLD=900
WHISPER_THREADS=8
WHISPER_LANG=auto
# IMPORTANT: keep yt-dlp CURRENT (YouTube breaks old versions). setup-vps.sh
# installs the latest standalone build; point this at it if not on PATH.
YTDLP_BIN=yt-dlp
# Optional: only needed if ffmpeg isn't on PATH (passed to yt-dlp --ffmpeg-location)
# FFMPEG_BIN=/usr/bin

# ── YouTube auth (beats "confirm you're not a bot") ──────────────────────────
# Export youtube.com cookies (Netscape format) and point here. REQUIRED for
# reliable downloads; refresh periodically (cookies expire). Either:
YTDLP_COOKIES_FILE=/opt/thestockie-influencer/cookies.txt
# ...or pull from a browser on the same host instead (chrome|firefox|safari):
# YTDLP_COOKIES_FROM_BROWSER=chrome

# ── Behaviour ────────────────────────────────────────────────────────────────
# Scratch dir for audio + whisper json (auto-created, cleaned per video).
WORK_DIR=/opt/thestockie-influencer/work
# Only keep / aggregate the last ~1 month.
WINDOW_DAYS=30
RETENTION_DAYS=30
MAX_VIDEO_AGE_DAYS=32
# Per channel, per run: at most this many recent videos.
MAX_VIDEOS_PER_CHANNEL=7
# Keep the .wav / whisper .json around for debugging (default false).
KEEP_AUDIO=false

# Path to the influencer list (relative to the working directory).
INFLUENCERS_FILE=config/influencers.json

# ── Super investors (13F) — used by superinvestor-job ────────────────────────
SUPERINVESTORS_FILE=config/superinvestors.json
# SEC requires a descriptive User-Agent with contact info.
EDGAR_USER_AGENT=thestockie-influencer you@example.com
# Optional OpenFIGI key for higher CUSIP→ticker rate limits (works without one).
# OPENFIGI_API_KEY=
